# petbnb — variables de entorno
# Copia este fichero a `.env` y rellena los valores reales.
# En producción, configúralas en Vercel → Project Settings → Environment Variables.

# --- Públicas (van al cliente; protegidas por RLS) ---
# Prefijo VITE_ obligatorio para que Vite las exponga al navegador.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Secretas (SOLO servidor; NUNCA con prefijo VITE_) ---
# service_role omite RLS: solo se usa desde server functions (createServerFn / *.server.ts).
# Obtenla en Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Usada desde la EPIC 1 (matching con Claude). Servidor únicamente.
ANTHROPIC_API_KEY=your-anthropic-api-key
